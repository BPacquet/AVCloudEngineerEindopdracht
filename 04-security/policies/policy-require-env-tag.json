{
  "$schema": "https://schema.management.azure.com/schemas/2019-09-01/policyDefinition.json#",
  "name": "require-contoso-governance-tags",
  "displayName": "Require Contoso governance tags",
  "description": "Ensures all mandatory Contoso governance tags exist and contain approved values.",
  "mode": "Indexed",
  "metadata": {
    "category": "Tags",
    "version": "1.1.0",
    "author": "Bjorn Pacquet"
  },
  "parameters": {
    "effect": {
      "type": "String",
      "metadata": {
        "displayName": "Effect",
        "description": "Policy enforcement mode."
      },
      "allowedValues": [
        "Deny",
        "Audit",
        "Disabled"
      ],
      "defaultValue": "Deny"
    },
    "allowedEnvironments": {
      "type": "Array",
      "metadata": {
        "displayName": "Allowed environments",
        "description": "Allowed values for the Environment tag."
      },
      "defaultValue": [
        "dev",
        "tst",
        "prd"
      ]
    },
    "requiredApplication": {
      "type": "String",
      "metadata": {
        "displayName": "Required application",
        "description": "Required value for the Application tag."
      },
      "defaultValue": "contoso-manufacturing"
    },
    "requiredOwner": {
      "type": "String",
      "metadata": {
        "displayName": "Required owner",
        "description": "Required value for the Owner tag."
      },
      "defaultValue": "team-cloud@contoso.be"
    },
    "requiredCostCenter": {
      "type": "String",
      "metadata": {
        "displayName": "Required cost center",
        "description": "Required value for the CostCenter tag."
      },
      "defaultValue": "CC-IT-001"
    },
    "allowedDataClassifications": {
      "type": "Array",
      "metadata": {
        "displayName": "Allowed data classifications",
        "description": "Allowed values for the DataClassification tag."
      },
      "defaultValue": [
        "internal",
        "confidential"
      ]
    }
  },
  "policyRule": {
    "if": {
      "anyOf": [
        {
          "field": "tags['Environment']",
          "notIn": "[parameters('allowedEnvironments')]"
        },
        {
          "field": "tags['Application']",
          "notEquals": "[parameters('requiredApplication')]"
        },
        {
          "field": "tags['Owner']",
          "notEquals": "[parameters('requiredOwner')]"
        },
        {
          "field": "tags['CostCenter']",
          "notEquals": "[parameters('requiredCostCenter')]"
        },
        {
          "field": "tags['DataClassification']",
          "notIn": "[parameters('allowedDataClassifications')]"
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]"
    }
  }
}
