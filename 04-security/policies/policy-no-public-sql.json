{
  "$schema": "https://schema.management.azure.com/schemas/2019-09-01/policyDefinition.json#",
  "name": "deny-public-sql-database",
  "displayName": "Deny public network access on Azure SQL Database",
  "description": "Denies creation or update of Azure SQL Servers with public network access enabled. All access must go through Private Endpoints.",
  "mode": "Indexed",
  "metadata": {
    "category": "SQL",
    "version": "1.0.0",
    "author": "delaware cloud practice"
  },
  "parameters": {
    "effect": {
      "type": "String",
      "metadata": {
        "displayName": "Effect"
      },
      "allowedValues": [
        "Deny",
        "Audit",
        "Disabled"
      ],
      "defaultValue": "Deny"
    }
  },
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.Sql/servers"
        },
        {
          "field": "Microsoft.Sql/servers/publicNetworkAccess",
          "notEquals": "Disabled"
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]"
    }
  }
}
