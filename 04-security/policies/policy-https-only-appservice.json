{
  "$schema": "https://schema.management.azure.com/schemas/2019-09-01/policyDefinition.json#",
  "name": "require-https-appservice",
  "displayName": "Require HTTPS-only on App Service",
  "description": "Denies the creation or modification of App Service resources that do not enforce HTTPS. HTTP traffic must be redirected to HTTPS.",
  "mode": "Indexed",
  "metadata": {
    "category": "App Service",
    "version": "1.0.0",
    "author": "delaware cloud practice"
  },
  "parameters": {
    "effect": {
      "type": "String",
      "metadata": {
        "displayName": "Effect"
      },
      "allowedValues": [
        "Deny",
        "Audit",
        "Disabled"
      ],
      "defaultValue": "Deny"
    }
  },
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.Web/sites"
        },
        {
          "field": "Microsoft.Web/sites/httpsOnly",
          "notEquals": true
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]"
    }
  }
}
