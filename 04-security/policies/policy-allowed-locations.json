{
  "$schema": "https://schema.management.azure.com/schemas/2019-09-01/policyDefinition.json#",
  "name": "allowed-locations-contoso",
  "displayName": "Allowed locations — West Europe and North Europe only",
  "description": "Restricts resource deployment to approved Azure regions. Contoso Manufacturing only uses West Europe (Amsterdam) and North Europe (Dublin) for GDPR and data residency compliance.",
  "mode": "Indexed",
  "metadata": {
    "category": "General",
    "version": "1.0.0",
    "author": "delaware cloud practice"
  },
  "parameters": {
    "allowedLocations": {
      "type": "Array",
      "metadata": {
        "displayName": "Allowed locations",
        "description": "The list of allowed locations",
        "strongType": "location"
      },
      "defaultValue": [
        "westeurope",
        "northeurope",
        "global"
      ]
    },
    "effect": {
      "type": "String",
      "allowedValues": [
        "Deny",
        "Audit",
        "Disabled"
      ],
      "defaultValue": "Deny"
    }
  },
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "location",
          "notIn": "[parameters('allowedLocations')]"
        },
        {
          "field": "location",
          "notEquals": "global"
        },
        {
          "field": "type",
          "notEquals": "Microsoft.AzureActiveDirectory/b2cDirectories"
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]"
    }
  }
}
